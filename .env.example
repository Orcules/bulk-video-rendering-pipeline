# Bulk Video Rendering Pipeline — environment template
# Copy to .env and fill in your own values. Never commit real keys.

# Animation providers (GoAPI relay)
KLING_API_KEY=your-kling-api-key
MINIMAX_API_KEY=your-minimax-api-key

# Voiceover
ELEVEN_LABS_API_KEY=your-elevenlabs-api-key

# OpenAI (optional — used for the TTS fallback)
OPENAI_API_KEY=your-openai-api-key

# ZapCap subtitles
ZAPCAP_API_KEY=your-zapcap-api-key
ZAPCAP_WEBHOOK_SECRET=your-zapcap-webhook-secret

# Google Cloud Storage
GCS_BUCKET_NAME=your-gcs-bucket
# Also place your Google service_account.json in the repo root (gitignored).

# Google Sheets
GOOGLE_SHEET_ID=your-google-sheet-id

# Google service account (used for Sheets / GCS auth)
SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
SERVICE_ACCOUNT_KEY=your-service-account-private-key
